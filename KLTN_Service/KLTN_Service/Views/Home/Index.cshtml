@{
    ViewData["Title"] = "Tổng quan hệ thống";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-xl col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 5px solid #6f42c1 !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-uppercase mb-1" style="font-size: 0.75rem; color: #6f42c1;">Tổng Vi Phạm (Tất Cả)</div>
                            <div class="h3 mb-0 fw-bold text-dark" id="txt-total-all">0</div>
                        </div>
                        <div class="col-auto"><i class="bi bi-database-fill fs-2 opacity-50" style="color: #6f42c1;"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 5px solid #dc3545 !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1" style="font-size: 0.75rem;">Vi Phạm (Hôm nay)</div>
                            <div class="h3 mb-0 fw-bold text-dark" id="txt-total-today">0</div>
                        </div>
                        <div class="col-auto"><i class="bi bi-shield-exclamation fs-2 text-danger opacity-50"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-4 mb-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 5px solid #fd7e14 !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.75rem; color: #fd7e14 !important;">Vượt Đèn Đỏ</div>
                            <div class="h3 mb-0 fw-bold text-dark" id="txt-dendo-today">0</div>
                        </div>
                        <div class="col-auto"><i class="bi bi-stoplights fs-2 text-warning opacity-50" style="color: #fd7e14 !important;"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-4 mb-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 5px solid #0d6efd !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Đi Sai Làn</div>
                            <div class="h3 mb-0 fw-bold text-dark" id="txt-sailan-today">0</div>
                        </div>
                        <div class="col-auto"><i class="bi bi-sign-turn-right fs-2 text-primary opacity-50"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-4 mb-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 5px solid #20c997 !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.8rem; color: #20c997 !important;">Không Mũ</div>
                            <div class="h3 mb-0 fw-bold text-dark" id="txt-khongmu-today">0</div>
                        </div>
                        <div class="col-auto"><i class="bi bi-person-x fs-2 opacity-50" style="color: #20c997;"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold text-primary"><i class="bi bi-graph-up me-2"></i>Lưu lượng Vi phạm (7 ngày qua)</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="height: 300px;"><canvas id="violationLineChart"></canvas></div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold text-primary"><i class="bi bi-pie-chart-fill me-2"></i>Tỷ lệ Lỗi (Tất cả thời gian)</h6>
                </div>
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="chart-pie" style="height: 250px;"><canvas id="violationPieChart"></canvas></div>
                    <div class="mt-4 text-center small">
                        <span class="me-2"><i class="bi bi-circle-fill text-warning"></i> Vượt đèn đỏ</span>
                        <span class="me-2"><i class="bi bi-circle-fill text-primary"></i> Sai làn</span>
                        <span class="me-2"><i class="bi bi-circle-fill text-success"></i> Không mũ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Biến động mới nhất từ Camera</h6>
                    <a href="/ViPham/Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th class="ps-4">Hình ảnh</th>
                                    <th>Loại vi phạm</th>
                                    <th>Camera</th>
                                    <th>Thời gian</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody id="table-recent-violations">
                                <tr><td colspan="5" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary me-2"></div> Đang tải dữ liệu...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="violationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-camera-fill me-2"></i> TRÍCH XUẤT HÌNH ẢNH VI PHẠM</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-bold text-secondary d-flex justify-content-between">
                                <span><i class="bi bi-image"></i> Hình ảnh toàn cảnh</span>
                                <small class="text-primary"><i class="bi bi-mouse3-fill"></i> Lăn chuột để thu phóng, kéo để di chuyển</small>
                            </div>
                            <div id="fullImgContainer" class="card-body p-2 text-center bg-dark rounded-bottom d-flex align-items-center justify-content-center" style="overflow: hidden; position: relative; min-height: 400px;">
                                <img id="modalFullImg" src="" class="img-fluid rounded" style="max-height: 550px; cursor: zoom-in;" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-white fw-bold text-secondary"><i class="bi bi-search"></i> Cận cảnh biển số</div>
                            <div class="card-body p-3 text-center bg-dark rounded-bottom">
                                <div id="plateContainer" class="p-2 border border-danger border-2 rounded bg-dark d-flex justify-content-center align-items-center" style="overflow: hidden; min-height: 110px;">
                                    <img id="modalPlateImg" src="" class="rounded shadow" style="max-width: 100%; max-height: 85px; object-fit: contain; image-rendering: crisp-edges; cursor: zoom-in;" />
                                </div>
                                <div id="noPlateMsg" class="text-white small mt-2 d-none">Không có ảnh biển số cận cảnh</div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm border-top border-primary border-3">
                            <div class="card-body">
                                <h6 class="text-primary small text-uppercase border-bottom pb-2 mb-3 fw-bold">Nghiệp vụ xử lý</h6>
                                <input type="hidden" id="modalViolationId" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted mb-1">Nhập biển số chính xác:</label>
                                    <input type="text" id="modalBienSoInput" class="form-control text-uppercase fw-bold text-danger border-danger" placeholder="VD: 43A-403.61" />
                                </div>

                                <p class="mb-2"><strong>Hành vi:</strong> <span id="modalLoi" class="text-danger fw-bold"></span></p>
                                <p class="mb-0"><strong>Thời điểm:</strong> <span id="modalTime" class="text-muted"></span></p>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="button" class="btn btn-success fw-bold py-2 shadow-sm" onclick="approveViolation()">
                                <i class="bi bi-check-circle-fill me-2"></i> Xác nhận & Duyệt
                            </button>
                            <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Đóng cửa sổ</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(document).ready(function() {
            var ctxLine = document.getElementById("violationLineChart").getContext('2d');
            var ctxPie = document.getElementById("violationPieChart").getContext('2d');

            enableZoomAndPan('modalFullImg', 'fullImgContainer');
            enableZoomAndPan('modalPlateImg', 'plateContainer');

            $.ajax({
                url: '/Home/GetDashboardData',
                type: 'GET',
                success: function (res) {

                    $('#txt-total-all').text(res.allTime.total);
                    $('#txt-total-today').text(res.today.total);
                    $('#txt-dendo-today').text(res.today.denDo);
                    $('#txt-sailan-today').text(res.today.saiLan);
                    $('#txt-khongmu-today').text(res.today.khongMu);

                    new Chart(ctxLine, {
                        type: 'line',
                        data: {
                            labels: res.chart7Days.labels,
                            datasets: [{
                                label: "Số lượt vi phạm",
                                lineTension: 0.3,
                                backgroundColor: "rgba(78, 115, 223, 0.05)",
                                borderColor: "rgba(78, 115, 223, 1)",
                                pointRadius: 4,
                                data: res.chart7Days.data,
                                fill: true
                            }]
                        },
                        options: { maintainAspectRatio: false, plugins: { legend: { display: false } } }
                    });

                    new Chart(ctxPie, {
                        type: 'doughnut',
                        data: {
                            labels: ["Vượt Đèn Đỏ", "Sai Làn", "Không Mũ"],
                            datasets: [{
                                data: [res.allTime.denDo, res.allTime.saiLan, res.allTime.khongMu],
                                backgroundColor: ['#ffc107', '#0d6efd', '#20c997']
                            }],
                        },
                        options: { maintainAspectRatio: false, cutout: '75%', plugins: { legend: { display: false } } }
                    });

                    let tbody = $('#table-recent-violations');
                    tbody.empty();

                    if(res.recentList && res.recentList.length === 0) {
                        tbody.append('<tr><td colspan="5" class="text-center text-muted py-3">Chưa có vi phạm nào</td></tr>');
                    } else {
                        res.recentList.forEach(function(item) {
                            let badgeClass = "bg-danger";
                            if(item.loaiViPham.includes("Vuot Den")) badgeClass = "bg-warning text-dark";
                            else if(item.loaiViPham.includes("Sai Lan")) badgeClass = "bg-primary";
                            else if(item.loaiViPham.includes("Khong Mu")) badgeClass = "bg-info text-dark";

                            let statusBadge = item.trangThai === "Chờ duyệt" || item.trangThai === "Chưa xử lý"
                                ? '<span class="badge bg-secondary">Chưa xử lý</span>'
                                : `<span class="badge bg-success">${item.trangThai}</span>`;

                            let imageUrl = `/api/api/images/vi_pham/${item.hinhAnh}`;

                            let imgTagHtml = `<div class="d-inline-block border rounded overflow-hidden shadow-sm"
                                                   style="width: 100px; height: 60px; cursor: pointer; transition: transform 0.2s;"
                                                   onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'"
                                                   onclick="showViolationDetail(${item.id}, '${item.hinhAnh}', '${item.hinhAnhBienSo || ''}', '${item.bienSo}', '${item.loaiViPham}', '${item.thoiGian}')">
                                                <img src="${imageUrl}" onerror="this.src='https://placehold.co/100x60?text=No+Image'" style="width: 100%; height: 100%; object-fit: cover;"/>
                                              </div>`;

                            let row = `<tr>
                                        <td class="ps-4 py-2">${imgTagHtml}</td>
                                        <td><span class="badge ${badgeClass}">${item.loaiViPham}</span></td>
                                        <td><i class="bi bi-camera-video text-muted me-1"></i> ${item.tenCamera ? item.tenCamera : "Camera " + item.cameraId}</td>
                                        <td>${item.thoiGian}</td>
                                        <td>${statusBadge}</td>
                                       </tr>`;
                            tbody.append(row);
                        });
                    }
                }
            });
        });

        function enableZoomAndPan(imgId, containerId) {
            const img = document.getElementById(imgId);
            const container = document.getElementById(containerId);
            let scale = 1, isDragging = false, startX, startY, translateX = 0, translateY = 0;

            img.style.transition = "transform 0.1s ease";
            img.style.transformOrigin = "center center";

            img.resetZoom = function () {
                scale = 1; translateX = 0; translateY = 0;
                img.style.transform = `translate(0px, 0px) scale(1)`;
                img.style.cursor = 'zoom-in';
            };

            container.addEventListener('wheel', function (e) {
                e.preventDefault();
                const zoomSpeed = 0.15;
                if (e.deltaY < 0) scale += zoomSpeed; else scale -= zoomSpeed;
                scale = Math.max(1, Math.min(scale, 6));
                img.style.cursor = scale === 1 ? 'zoom-in' : 'grab';
                img.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
            });

            img.addEventListener('mousedown', function (e) {
                if (scale > 1) {
                    isDragging = true;
                    startX = e.clientX - translateX; startY = e.clientY - translateY;
                    img.style.cursor = 'grabbing'; img.style.transition = "none";
                }
            });

            window.addEventListener('mousemove', function (e) {
                if (!isDragging) return;
                e.preventDefault();
                translateX = e.clientX - startX; translateY = e.clientY - startY;
                img.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
            });

            window.addEventListener('mouseup', function () {
                if (isDragging) {
                    isDragging = false;
                    img.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
                    img.style.transition = "transform 0.1s ease";
                }
            });
        }

        function showViolationDetail(id, fullImg, plateImg, bienSo, loi, thoiGian) {
            document.getElementById('modalViolationId').value = id;

            let fullImgTag = document.getElementById('modalFullImg');
            let plateImgTag = document.getElementById('modalPlateImg');

            if (fullImgTag.resetZoom) fullImgTag.resetZoom();
            if (plateImgTag.resetZoom) plateImgTag.resetZoom();

            fullImgTag.src = "/api/api/images/vi_pham/" + fullImg;

            const plateContainer = document.getElementById('plateContainer');
            const noPlateMsg = document.getElementById('noPlateMsg');

            if (plateImg && plateImg.trim() !== '' && plateImg !== 'null') {
                plateImgTag.src = "/api/api/images/plates/" + plateImg;
                plateContainer.classList.remove('d-none');
                noPlateMsg.classList.add('d-none');
            } else {
                plateContainer.classList.add('d-none');
                noPlateMsg.classList.remove('d-none');
            }

            document.getElementById('modalLoi').innerText = loi;
            document.getElementById('modalTime').innerText = thoiGian;

            let autoPlate = bienSo.replace('ID ', '').replace('Xe ', '').trim();
            if(!isNaN(autoPlate)) autoPlate = "";
            document.getElementById('modalBienSoInput').value = autoPlate;

            var myModal = new bootstrap.Modal(document.getElementById('violationModal'));
            myModal.show();
        }

        function approveViolation() {
            var id = $('#modalViolationId').val();
            var bienSoMoi = $('#modalBienSoInput').val().trim();

            if (!bienSoMoi) {
                alert("Vui lòng nhập biển số xe trước khi duyệt!");
                $('#modalBienSoInput').focus();
                return;
            }

            var btn = event.currentTarget;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
            btn.disabled = true;

            $.ajax({
                url: '/api/api/violations/approve',
                type: 'POST',
                data: { id: id, bienSoMoi: bienSoMoi },
                success: function (res) {
                    if (res.status === 'success') {
                        location.reload();
                    } else {
                        alert("Lỗi: " + res.message);
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }
                },
                error: function () {
                    alert("Lỗi kết nối đến máy chủ!");
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            });
        }
    </script>
}