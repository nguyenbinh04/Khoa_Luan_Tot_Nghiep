@model IEnumerable<KLTN_Service.Models.LichSuViPham>

@{
    ViewData["Title"] = "Quản lý vi phạm";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-danger fw-bold m-0"><i class="bi bi-shield-lock-fill me-2"></i>HỆ THỐNG GIÁM SÁT VI PHẠM</h2>
        <span class="badge bg-secondary fs-6 shadow-sm">Tổng số: @Model.Count() vụ việc</span>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-2">
            <ul class="nav nav-pills nav-fill gap-2 p-1 small bg-light rounded-pill" id="violation-tabs">
                <li class="nav-item">
                    <a class="nav-link active rounded-pill fw-bold filter-tab" href="#" data-filter="" style="transition: 0.3s;">
                        <i class="bi bi-list-task me-1"></i> Tất Cả
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill fw-bold filter-tab text-dark" href="#" data-filter="Vuot Den Do">
                        <i class="bi bi-stoplights-fill text-danger me-1"></i> Vượt Đèn Đỏ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill fw-bold filter-tab text-dark" href="#" data-filter="Sai Lan">
                        <i class="bi bi-sign-turn-right-fill text-warning me-1"></i> Đi Sai Làn
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill fw-bold filter-tab text-dark" href="#" data-filter="Khong Mu">
                        <i class="bi bi-person-bounding-box text-success me-1"></i> Không Mũ BH
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill fw-bold filter-tab text-dark" href="#" data-filter="+">
                        <i class="bi bi-exclamation-octagon-fill text-danger me-1"></i> Vi Phạm Kép (Nhiều lỗi)
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center" id="violationTable">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Biển Số</th>
                            <th>Lỗi Vi Phạm</th>
                            <th>Thời Gian</th>
                            <th>Trạng Thái</th>
                            <th style="width: 180px;">Ảnh Bằng Chứng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">#@item.Id</td>
                                <td><span class="badge bg-primary px-3 py-2 fs-6 shadow-sm">@item.BienSo</span></td>
                                <td class="text-danger fw-bold">@item.LoaiViPham</td>
                                <td>@item.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>
                                    <span class="badge rounded-pill @(item.TrangThaiXuLy == "Chưa xử lý" ? "bg-warning text-dark" : "bg-success")">
                                        @item.TrangThaiXuLy
                                    </span>
                                </td>
                                <td>
                                    <div class="position-relative d-inline-block shadow-sm rounded overflow-hidden"
                                         style="cursor: pointer; transition: transform 0.2s;"
                                         onmouseover="this.style.transform='scale(1.05)'"
                                         onmouseout="this.style.transform='scale(1)'"
                                         onclick="showViolationDetail(@item.Id, '@item.DuongDanAnh', '@item.DuongDanAnhBienSo', '@item.BienSo', '@item.LoaiViPham', '@item.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")')">

                                        <img src="/images/vi_pham/@item.DuongDanAnh" class="img-fluid" style="width: 150px; height: 85px; object-fit: cover;" />

                                        @if (!string.IsNullOrEmpty(item.DuongDanAnhBienSo))
                                        {
                                            <div style="position: absolute; bottom: 0; right: 0; background: rgba(220, 53, 69, 0.8); padding: 2px;">
                                                <img src="/images/plates/@item.DuongDanAnhBienSo" style="width: 50px; height: auto; border: 1px solid white;" />
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="violationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-camera-fill me-2"></i> TRÍCH XUẤT HÌNH ẢNH VI PHẠM</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-bold text-secondary d-flex justify-content-between">
                                <span><i class="bi bi-image"></i> Hình ảnh toàn cảnh</span>
                                <small class="text-primary"><i class="bi bi-mouse3-fill"></i> Lăn chuột để thu phóng, kéo để di chuyển</small>
                            </div>
                            <div id="fullImgContainer" class="card-body p-2 text-center bg-dark rounded-bottom d-flex align-items-center justify-content-center" style="overflow: hidden; position: relative;">
                                <img id="modalFullImg" src="" class="img-fluid rounded" style="max-height: 550px; cursor: zoom-in;" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-white fw-bold text-secondary"><i class="bi bi-search"></i> Cận cảnh biển số</div>
                            <div class="card-body p-3 text-center bg-dark rounded-bottom">
                                <div id="plateContainer" class="p-1 border border-danger border-2 rounded bg-dark" style="overflow: hidden;">
                                    <img id="modalPlateImg" src="" class="rounded" style="width: 100%; height: 120px; object-fit: contain; image-rendering: crisp-edges; cursor: zoom-in;" />
                                </div>
                                <div id="noPlateMsg" class="text-white small mt-2 d-none">Không có ảnh biển số cận cảnh</div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm border-top border-primary border-3">
                            <div class="card-body">
                                <h6 class="text-primary small text-uppercase border-bottom pb-2 mb-3 fw-bold">Nghiệp vụ xử lý</h6>

                                <input type="hidden" id="modalViolationId" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted mb-1">Nhập biển số chính xác:</label>
                                    <input type="text" id="modalBienSoInput" class="form-control text-uppercase fw-bold text-danger border-danger" placeholder="VD: 43A-403.61" />
                                    <small class="text-muted" style="font-size: 0.75rem;">*Nhìn vào ảnh cận cảnh để gõ lại</small>
                                </div>

                                <p class="mb-2"><strong>Hành vi:</strong> <span id="modalLoi" class="text-danger fw-bold"></span></p>
                                <p class="mb-0"><strong>Thời điểm:</strong> <span id="modalTime" class="text-muted"></span></p>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="button" class="btn btn-success fw-bold py-2 shadow-sm" onclick="approveViolation()">
                                <i class="bi bi-check-circle-fill me-2"></i> Xác nhận & Duyệt
                            </button>
                            <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Đóng cửa sổ</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            var table = $('#violationTable').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "order": [[ 0, "desc" ]],
                "columnDefs": [{ "orderable": false, "targets": 5 }]
            });

            $('.filter-tab').on('click', function (e) {
                e.preventDefault();
                $('.filter-tab').removeClass('active bg-danger text-white').addClass('text-dark');
                $(this).removeClass('text-dark').addClass('active bg-danger text-white');
                var keyword = $(this).attr('data-filter');
                table.column(2).search(keyword).draw();
            });

            // KHỞI TẠO TÍNH NĂNG ZOOM CHO ẢNH TOÀN CẢNH VÀ ẢNH BIỂN SỐ
            enableZoomAndPan('modalFullImg', 'fullImgContainer');
            enableZoomAndPan('modalPlateImg', 'plateContainer');
        });

        // ================================================================
        // HÀM HỖ TRỢ ZOOM VÀ KÉO THẢ ẢNH BẰNG CHUỘT
        // ================================================================
        function enableZoomAndPan(imgId, containerId) {
            const img = document.getElementById(imgId);
            const container = document.getElementById(containerId);

            let scale = 1;
            let isDragging = false;
            let startX, startY, translateX = 0, translateY = 0;

            img.style.transition = "transform 0.1s ease";
            img.style.transformOrigin = "center center";

            // Khôi phục mặc định (sẽ gọi khi mở popup mới)
            img.resetZoom = function () {
                scale = 1;
                translateX = 0;
                translateY = 0;
                img.style.transform = `translate(0px, 0px) scale(1)`;
                img.style.cursor = 'zoom-in';
            };

            // Sự kiện lăn chuột (Cuộn)
            container.addEventListener('wheel', function (e) {
                e.preventDefault(); // Chặn cuộn trang web

                const zoomSpeed = 0.15;
                if (e.deltaY < 0) scale += zoomSpeed; // Lăn lên -> Phóng to
                else scale -= zoomSpeed; // Lăn xuống -> Thu nhỏ

                scale = Math.max(1, Math.min(scale, 6)); // Giới hạn zoom từ 1x đến 6x

                if (scale === 1) {
                    translateX = 0;
                    translateY = 0;
                    img.style.cursor = 'zoom-in';
                } else {
                    img.style.cursor = 'grab';
                }

                img.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
            });

            // Sự kiện nhấp chuột để bắt đầu kéo
            img.addEventListener('mousedown', function (e) {
                if (scale > 1) {
                    isDragging = true;
                    startX = e.clientX - translateX;
                    startY = e.clientY - translateY;
                    img.style.cursor = 'grabbing';
                    img.style.transition = "none"; // Tắt mượt để kéo không bị trễ nhịp
                }
            });

            // Sự kiện di chuột để kéo ảnh
            window.addEventListener('mousemove', function (e) {
                if (!isDragging) return;
                e.preventDefault();
                translateX = e.clientX - startX;
                translateY = e.clientY - startY;
                img.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
            });

            // Sự kiện nhả chuột
            window.addEventListener('mouseup', function () {
                if (isDragging) {
                    isDragging = false;
                    img.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
                    img.style.transition = "transform 0.1s ease"; // Bật lại độ mượt
                }
            });
        }

        // ================================================================

        function showViolationDetail(id, fullImg, plateImg, bienSo, loi, thoiGian) {
            document.getElementById('modalViolationId').value = id;

            let fullImgTag = document.getElementById('modalFullImg');
            let plateImgTag = document.getElementById('modalPlateImg');

            // Reset trạng thái Zoom về 1x trước khi load ảnh mới
            if (fullImgTag.resetZoom) fullImgTag.resetZoom();
            if (plateImgTag.resetZoom) plateImgTag.resetZoom();

            fullImgTag.src = "/images/vi_pham/" + fullImg;

            const plateContainer = document.getElementById('plateContainer');
            const noPlateMsg = document.getElementById('noPlateMsg');

            if (plateImg && plateImg.trim() !== '' && plateImg !== 'null') {
                plateImgTag.src = "/images/plates/" + plateImg;
                plateContainer.classList.remove('d-none');
                noPlateMsg.classList.add('d-none');
            } else {
                plateContainer.classList.add('d-none');
                noPlateMsg.classList.remove('d-none');
            }

            document.getElementById('modalLoi').innerText = loi;
            document.getElementById('modalTime').innerText = thoiGian;

            let autoPlate = bienSo.replace('ID ', '').replace('Xe ', '').trim();
            if(!isNaN(autoPlate)) autoPlate = "";
            document.getElementById('modalBienSoInput').value = autoPlate;

            var myModal = new bootstrap.Modal(document.getElementById('violationModal'));
            myModal.show();
        }

        function approveViolation() {
            var id = $('#modalViolationId').val();
            var bienSoMoi = $('#modalBienSoInput').val().trim();

            if (!bienSoMoi) {
                alert("Vui lòng nhập biển số xe trước khi duyệt!");
                $('#modalBienSoInput').focus();
                return;
            }

            var btn = event.currentTarget;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
            btn.disabled = true;

            $.ajax({
                url: '/api/api/violations/approve',
                type: 'POST',
                data: { id: id, bienSoMoi: bienSoMoi },
                success: function (res) {
                    if (res.status === 'success') {
                        location.reload();
                    } else {
                        alert("Lỗi: " + res.message);
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }
                },
                error: function () {
                    alert("Lỗi kết nối đến máy chủ!");
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            });
        }
    </script>
}