@{
    ViewData["Title"] = "Camera Trực Tiếp & Cấu Hình Vùng";
}

<style>
    .container {
        max-width: 98% !important;
        padding: 0 !important;
    }
</style>

<div class="container-fluid mt-4">
    <div class="row">

        <div class="col-xl-2 col-lg-3 col-md-4 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-primary text-white fw-bold py-3">
                    <i class="bi bi-cpu-fill fs-5 me-2"></i> BỘ ĐIỀU KHIỂN
                </div>
                <div class="card-body bg-light">
                    <div class="mb-3">
                        <label class="form-label fw-bold fs-6 text-dark">Lựa chọn Camera:</label>
                        <select id="cameraSelect" class="form-select border-primary fw-bold text-primary mb-3" onchange="clearCanvasOnSwitch()">
                            <option value="">Đang tải dữ liệu...</option>
                        </select>

                        <div class="mb-3 p-2 bg-white border rounded small shadow-sm text-break">
                            <span class="fw-bold text-dark"><i class="bi bi-link-45deg text-primary"></i> Đang dùng:</span>
                            <span id="currentVideoName" class="text-danger fw-bold ms-1">Chưa có dữ liệu</span>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <button class="btn btn-success btn-sm fw-bold flex-grow-1 shadow-sm" type="button" onclick="openCreateModal()">
                                <i class="bi bi-plus-circle"></i> Thêm
                            </button>
                            <button id="btn-edit" class="btn btn-primary btn-sm fw-bold flex-grow-1 shadow-sm" type="button" onclick="openEditModal()">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </button>
                            <button id="btn-delete" class="btn btn-danger btn-sm fw-bold flex-grow-1 shadow-sm" type="button" onclick="deleteCamera()">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-auto">
                        <button class="btn btn-success fw-bold flex-grow-1 shadow-sm py-2" type="button" onclick="startAI()">
                            <i class="bi bi-play-circle-fill me-1"></i> KHỞI ĐỘNG
                        </button>
                        <button class="btn btn-danger fw-bold shadow-sm py-2" type="button" onclick="stopAI()" title="Tắt hệ thống">
                            <i class="bi bi-stop-circle-fill"></i> TẮT
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-6 col-md-8 text-center mb-4">
            <h3 class="text-primary fw-bold mb-3"><i class="bi bi-camera-video"></i> HỆ THỐNG GIÁM SÁT REAL-TIME</h3>

            <div class="card shadow-lg border-0 bg-dark">
                <div id="video-container" class="card-body p-0 position-relative" style="width: 100%; overflow: hidden; min-height: 400px;">

                    <div id="offlineMsg" class="text-secondary d-flex flex-column justify-content-center align-items-center w-100 h-100" style="position: absolute; top: 0; left: 0; z-index: 3;">
                        <i class="bi bi-eye-slash-fill" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">Hệ thống AI đang tắt</h5>
                        <p class="small">Vui lòng chọn Camera và bấm Khởi động AI.</p>
                    </div>

                    <img id="video-stream" src="" class="img-fluid" alt="" style="display: none; width: 100%; position: relative; z-index: 1;" />

                    <canvas id="overlay-canvas" style="position: absolute; top: 0; left: 0; cursor: crosshair; z-index: 2;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-2 col-lg-3 col-md-12 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-danger text-white fw-bold py-3">
                    <i class="bi bi-pencil-square fs-5 me-2"></i> BẢNG VẼ VẠCH
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-4">Click trực tiếp vào màn hình để vẽ vùng cảnh báo.</p>

                    <div class="d-grid gap-2 mb-4">
                        <button id="btn-clear" type="button" class="btn btn-warning fw-bold"><i class="bi bi-eraser"></i> Xóa Vẽ Lại</button>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold fs-6">Loại vùng cảnh báo:</label>
                        <select id="loaiVung" class="form-select border-danger">
                            <option value="Vach_DenDo">Vùng Vượt Đèn Đỏ</option>
                            <option value="Lan_XeMay">Làn Xe Máy</option>
                            <option value="Lan_Oto">Làn Ô Tô</option>
                            <option value="Vung_DenGiaoThong">Vùng Đèn Giao Thông</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2 mb-4">
                        <button type="button" id="btn-save" class="btn btn-danger fw-bold shadow-sm" onclick="saveConfig()">
                            <i class="bi bi-save me-2"></i> LƯU CẤU HÌNH
                        </button>
                    </div>

                    <hr class="my-4" />
                    <p class="fw-bold mb-2 fs-6 text-secondary">Tọa độ hiện tại (JSON):</p>
                    <textarea id="toa-do-output" class="form-control form-control-sm text-monospace" rows="4" readonly style="font-size: 10px; background-color: #f8f9fa;"></textarea>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="createCameraModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-camera-fill me-2"></i>Thêm Camera Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên Camera / Vị trí:</label>
                    <input type="text" id="newCameraName" class="form-control" placeholder="VD: CAM 01 - Ngã Tư Sở">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Đường dẫn Camera (RTSP/HTTP):</label>
                    <input type="text" id="newCameraPath" class="form-control" placeholder="Để trống nếu muốn tải video bên dưới">
                </div>
                <hr>
                <div class="mb-3">
                    <label class="form-label fw-bold text-success">Hoặc Tải Video Offline lên:</label>
                    <input type="file" id="newCameraVideo" class="form-control" accept="video/*">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-success">Tên File lưu trữ (Tùy chọn):</label>
                    <input type="text" id="newCustomFileName" class="form-control border-success" placeholder="Để trống sẽ lấy tên gốc của video">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-success fw-bold" id="btnSubmitNewCamera" onclick="submitNewCamera()">Khởi Tạo</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editCameraModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Chỉnh Sửa Camera</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editCameraId">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên Camera:</label>
                    <input type="text" id="editCameraName" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Thay Đường dẫn (RTSP/HTTP) mới:</label>
                    <input type="text" id="editCameraPath" class="form-control" placeholder="Nhập link để ghi đè dữ liệu cũ">
                </div>
                <hr>
                <div class="mb-3">
                    <label class="form-label fw-bold text-primary">Hoặc Tải Video thay thế:</label>
                    <input type="file" id="editCameraVideo" class="form-control" accept="video/*">
                    <small class="text-muted">Chọn file sẽ xóa đường dẫn cũ.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-primary">Tên File Video (Tùy chọn):</label>
                    <input type="text" id="editCustomFileName" class="form-control border-primary" placeholder="Để trống sẽ lấy tên gốc của video">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-primary fw-bold" id="btnSubmitEditCamera" onclick="submitEditCamera()">Lưu Cập Nhật</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let points = [];
        let allCameras = [];

        function saveUIState() {
            var camId = $('#cameraSelect').val();
            var loai = $('#loaiVung').val();
            if (camId) localStorage.setItem('lastCameraId', camId);
            if (loai) localStorage.setItem('lastLoaiVung', loai);
        }

        function updateVideoFileNameDisplay() {
            let selectedId = $('#cameraSelect').val();
            if (!selectedId) {
                $('#currentVideoName').text("Chưa có dữ liệu").removeClass('text-success text-primary').addClass('text-danger');
                return;
            }

            let selectedCam = allCameras.find(c => c.id == selectedId);
            if (selectedCam && selectedCam.duongDan) {
                let isStream = selectedCam.duongDan.startsWith('http') || selectedCam.duongDan.startsWith('rtsp');
                if(isStream) {
                    $('#currentVideoName').text(selectedCam.duongDan).removeClass('text-danger text-success').addClass('text-primary');
                } else {
                    $('#currentVideoName').text(selectedCam.duongDan).removeClass('text-danger text-primary').addClass('text-success');
                }
            } else {
                $('#currentVideoName').text("Chưa có video!").removeClass('text-success text-primary').addClass('text-danger');
            }
        }

        function loadCamerasFromDB(selectId = null) {
            $.ajax({
                url: '/api/api/camera/list',
                type: 'GET',
                success: function(res) {
                    if(res.status === 'success' && res.data) {
                        allCameras = res.data;
                        let html = '';

                        allCameras.forEach(cam => {
                            html += `<option value="${cam.id}">${cam.tenCamera}</option>`;
                        });

                        if (html === '') {
                            html = '<option value="">Chưa có Camera nào...</option>';
                            $('#btn-edit, #btn-delete').prop('disabled', true);
                        } else {
                            $('#btn-edit, #btn-delete').prop('disabled', false);
                        }

                        $('#cameraSelect').html(html);

                        var lastCam = localStorage.getItem('lastCameraId');
                        var lastVung = localStorage.getItem('lastLoaiVung');

                        if (selectId) {
                            $('#cameraSelect').val(selectId);
                            localStorage.setItem('lastCameraId', selectId);
                        } else if (lastCam && $(`#cameraSelect option[value='${lastCam}']`).length > 0) {
                            $('#cameraSelect').val(lastCam);
                        } else {
                            saveUIState();
                        }

                        if (lastVung) {
                            $('#loaiVung').val(lastVung);
                        }

                        updateVideoFileNameDisplay();
                        loadZoneFromServer();
                    }
                }
            });
        }

        function loadZoneFromServer() {
            var cameraId = $('#cameraSelect').val();
            var loaiVung = $('#loaiVung').val();

            if(!cameraId) {
                points = []; ctx.clearRect(0, 0, canvas.width, canvas.height); output.value = ""; return;
            }

            $.ajax({
                url: '/api/api/config/coordinates/' + cameraId,
                type: 'GET',
                success: function (res) {
                    points = []; ctx.clearRect(0, 0, canvas.width, canvas.height); output.value = "";
                    if (res.status === 'success' && res.data) {
                        var zone = res.data.find(x => x.loaiVung === loaiVung);
                        if (zone && zone.toaDoJson && zone.toaDoJson !== '[]') {
                            points = JSON.parse(zone.toaDoJson);
                            output.value = zone.toaDoJson;
                            if (img.naturalWidth > 0 && img.style.display !== 'none') drawShape();
                        }
                    }
                }
            });
        }

        function saveConfig() {
            let jsonStr = JSON.stringify(points);
            if (points.length > 0 && points.length < 3) { alert("Vui lòng click ít nhất 3 điểm!"); return; }
            if (points.length === 0) {
                if (!confirm("XÓA cấu hình của vùng hiện tại khỏi AI. Tiếp tục?")) return;
                jsonStr = "[]";
            }

            let btn = document.getElementById('btn-save');
            let oldText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';
            btn.disabled = true;

            var cameraId = $('#cameraSelect').val();
            if(!cameraId) { alert("Lỗi: Chưa chọn Camera!"); btn.innerHTML = oldText; btn.disabled = false; return; }

            var formData = new FormData();
            formData.append("cameraId", cameraId);
            formData.append("loaiVung", $('#loaiVung').val());
            formData.append("toaDoJson", jsonStr);

            $.ajax({
                url: '/api/api/config/save', type: 'POST', data: formData, processData: false, contentType: false,
                success: function (res) { alert("Thành công: " + res.message); btn.innerHTML = oldText; btn.disabled = false; loadZoneFromServer(); },
                error: function () { alert("Lỗi kết nối API."); btn.innerHTML = oldText; btn.disabled = false; }
            });
        }

        function openCreateModal() {
            $('#newCameraName').val('');
            $('#newCameraPath').val('');
            $('#newCameraVideo').val('');
            $('#newCustomFileName').val('');
            new bootstrap.Modal(document.getElementById('createCameraModal')).show();
        }

        function submitNewCamera() {
            var camName = $('#newCameraName').val().trim();
            var camPath = $('#newCameraPath').val().trim();
            var fileInput = document.getElementById('newCameraVideo').files[0];
            var customName = $('#newCustomFileName').val().trim();

            if (!camName) { alert("Vui lòng nhập tên Camera!"); return; }

            var formData = new FormData();
            formData.append("tenCamera", camName);
            if (camPath) formData.append("duongDan", camPath);
            if (fileInput) formData.append("videoFile", fileInput);
            if (customName) formData.append("customFileName", customName);

            let btn = document.getElementById('btnSubmitNewCamera');
            let oldHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo...';
            btn.disabled = true;

            $.ajax({
                url: '/api/api/camera/create', type: 'POST', data: formData, processData: false, contentType: false,
                success: function (res) {
                    alert(res.message);
                    bootstrap.Modal.getInstance(document.getElementById('createCameraModal')).hide();
                    btn.innerHTML = oldHtml; btn.disabled = false;
                    loadCamerasFromDB(res.newId);
                },
                error: function (err) { alert("Lỗi tải lên!"); btn.innerHTML = oldHtml; btn.disabled = false; }
            });
        }

        function openEditModal() {
            let selectedId = $('#cameraSelect').val();
            if (!selectedId) { alert("Vui lòng chọn Camera cần sửa!"); return; }

            let selectedCam = allCameras.find(c => c.id == selectedId);

            $('#editCameraId').val(selectedCam.id);
            $('#editCameraName').val(selectedCam.tenCamera);
            $('#editCameraPath').val('');
            $('#editCameraVideo').val('');
            $('#editCustomFileName').val('');

            new bootstrap.Modal(document.getElementById('editCameraModal')).show();
        }

        function submitEditCamera() {
            var camId = $('#editCameraId').val();
            var camName = $('#editCameraName').val().trim();
            var camPath = $('#editCameraPath').val().trim();
            var fileInput = document.getElementById('editCameraVideo').files[0];
            var customName = $('#editCustomFileName').val().trim();

            if (!camName) { alert("Vui lòng nhập tên Camera!"); return; }

            var formData = new FormData();
            formData.append("id", camId);
            formData.append("newName", camName);
            if (camPath) formData.append("newPath", camPath);
            if (fileInput) formData.append("newVideo", fileInput);
            if (customName) formData.append("customFileName", customName);

            let btn = document.getElementById('btnSubmitEditCamera');
            let oldHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';
            btn.disabled = true;

            $.ajax({
                url: '/api/api/camera/update', type: 'POST', data: formData, processData: false, contentType: false,
                success: function (res) {
                    alert(res.message);
                    bootstrap.Modal.getInstance(document.getElementById('editCameraModal')).hide();
                    btn.innerHTML = oldHtml; btn.disabled = false;
                    loadCamerasFromDB(camId);
                },
                error: function (err) { alert("Lỗi tải lên!"); btn.innerHTML = oldHtml; btn.disabled = false; }
            });
        }

        function deleteCamera() {
            var select = document.getElementById('cameraSelect');
            var cameraId = select.value;
            if (!cameraId) { alert("Vui lòng chọn Camera cần xóa!"); return; }

            if (confirm("⚠️ CẢNH BÁO: XÓA vĩnh viễn [" + select.options[select.selectedIndex].text + "]?")) {
                let btn = document.getElementById('btn-delete');
                let oldHtml = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; btn.disabled = true;

                var formData = new FormData(); formData.append("id", cameraId);

                $.ajax({
                    url: '/api/api/camera/delete', type: 'POST', data: formData, processData: false, contentType: false,
                    success: function (res) {
                        alert(res.message); localStorage.removeItem('lastCameraId');
                        stopAI(true); btn.innerHTML = oldHtml; btn.disabled = false; loadCamerasFromDB();
                    }
                });
            }
        }

        function clearCanvasOnSwitch() {
            $('#btn-clear').click();
            updateVideoFileNameDisplay();
            loadZoneFromServer();
        }

        function startAI() {
             var cameraId = $('#cameraSelect').val();
             if (!cameraId) { alert("Vui lòng chọn Camera trước khi khởi động AI!"); return; }

             var formData = new FormData();
             formData.append("cameraId", cameraId);

             let btn = event.currentTarget;
             let oldText = btn.innerHTML;
             btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang khởi động AI...';
             btn.disabled = true;

             $.ajax({
                 url: '/api/api/ai/start', type: 'POST', data: formData, processData: false, contentType: false,
                 success: function (res) {
                     alert(res.message);
                     let img = document.getElementById('video-stream');
                     let retryCount = 0;

                     img.onload = function() {
                         $(img).show();
                         $('#offlineMsg').removeClass('d-flex').hide();
                     };

                     img.onerror = function() {
                         if (retryCount < 10) {
                             retryCount++;
                             setTimeout(() => { img.src = "http://127.0.0.1:5000/video_feed?t=" + new Date().getTime(); }, 1500);
                         } else {
                             $(img).hide();
                             $('#offlineMsg').addClass('d-flex').show();
                             img.onerror = function() {
                                 $(img).hide();
                                 $('#offlineMsg').addClass('d-flex').show();
                             };
                         }
                     };

                     img.src = "http://127.0.0.1:5000/video_feed?t=" + new Date().getTime();
                     btn.innerHTML = oldText; btn.disabled = false;
                 },
                error: function (err) {
                    let errorMsg = err.responseJSON ? err.responseJSON.message : "Đường truyền gián đoạn!";
                    alert("Lỗi: " + errorMsg);
                    btn.innerHTML = oldText; btn.disabled = false;
                }
             });
         }

        function stopAI(skipConfirm = false) {
            if(!skipConfirm && !confirm("Bạn có chắc chắn muốn tắt hệ thống AI?")) return;
            $.ajax({
                url: '/api/api/ai/stop', type: 'POST',
                success: function (res) {
                    if(!skipConfirm) alert(res.message);

                    $('#video-stream').hide().attr("src", "");
                    $('#offlineMsg').addClass('d-flex').show();
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                }
            });
        }

        const img = document.getElementById('video-stream');
        const canvas = document.getElementById('overlay-canvas');
        const ctx = canvas.getContext('2d');
        const output = document.getElementById('toa-do-output');

        $(document).ready(function () {
            loadCamerasFromDB();

            $('#cameraSelect').change(function() { saveUIState(); clearCanvasOnSwitch(); });
            $('#loaiVung').change(function() { saveUIState(); loadZoneFromServer(); });

            img.onload = function() {
                $(img).show();
                $('#offlineMsg').removeClass('d-flex').hide();
            };
            img.onerror = function() {
                $(img).hide();
                $('#offlineMsg').addClass('d-flex').show();
            };

            img.src = "http://127.0.0.1:5000/video_feed?t=" + new Date().getTime();

            function adjustCanvasSize() {
                if (img.clientWidth === 0) return;
                canvas.width = img.clientWidth;
                canvas.height = img.clientHeight;
                if (points.length > 0) drawShape();
            }

            setInterval(function() { if (img.naturalWidth > 0 && img.style.display !== 'none') adjustCanvasSize(); }, 500);
            $(window).resize(adjustCanvasSize);

            canvas.addEventListener('mousedown', function (e) {
                if (img.naturalWidth === 0 || img.style.display === 'none') { alert("Vui lòng khởi động AI trước khi vẽ!"); return; }
                const rect = canvas.getBoundingClientRect();

                const ratioX = img.naturalWidth / img.clientWidth;
                const ratioY = img.naturalHeight / img.clientHeight;

                points.push({ x: Math.round((e.clientX - rect.left) * ratioX), y: Math.round((e.clientY - rect.top) * ratioY) });
                drawShape(); output.value = JSON.stringify(points);
            });

            function drawShape() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                if (points.length === 0) return;

                const ratioX = canvas.width / img.naturalWidth;
                const ratioY = canvas.height / img.naturalHeight;

                ctx.beginPath();
                ctx.moveTo(points[0].x * ratioX, points[0].y * ratioY);
                for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x * ratioX, points[i].y * ratioY);
                if (points.length >= 3) ctx.closePath();

                let loaiVung = $('#loaiVung').val();
                ctx.fillStyle = loaiVung === 'Vach_DenDo' ? 'rgba(255, 0, 0, 0.3)' : loaiVung === 'Lan_XeMay' ? 'rgba(255, 255, 0, 0.3)' : loaiVung === 'Vung_DenGiaoThong' ? 'rgba(255, 0, 255, 0.3)' : 'rgba(0, 0, 255, 0.3)';
                ctx.strokeStyle = loaiVung === 'Vach_DenDo' ? 'red' : loaiVung === 'Lan_XeMay' ? 'yellow' : loaiVung === 'Vung_DenGiaoThong' ? 'magenta' : 'blue';

                if (points.length >= 3) ctx.fill();
                ctx.lineWidth = 2; ctx.stroke();

                points.forEach(p => {
                    ctx.beginPath(); ctx.arc(p.x * ratioX, p.y * ratioY, 5, 0, 2 * Math.PI);
                    ctx.fillStyle = 'white'; ctx.fill(); ctx.stroke();
                });
            }

            $('#btn-clear').click(function () { points = []; ctx.clearRect(0, 0, canvas.width, canvas.height); output.value = ""; });
        });
    </script>
}