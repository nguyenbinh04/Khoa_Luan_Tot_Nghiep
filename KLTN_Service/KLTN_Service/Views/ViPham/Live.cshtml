@{
    ViewData["Title"] = "Giám Sát Trực Tiếp";
}

<style>
        .container {
                max-width: 98% !important;
                padding: 0 !important;

    }
</style>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-auto mb-4" style="width: 280px; height: 400px; margin-top: 50px;">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-primary text-white fw-bold py-3">
                    <i class="bi bi-display fs-5 me-2"></i> ĐIỀU KHIỂN
                </div>
                <div class="card-body bg-light d-flex flex-column">
                    <div class="mb-4">
                        <label class="form-label fw-bold fs-6 text-dark">Lựa chọn Camera:</label>
                        <select id="cameraSelect" class="form-select border-primary fw-bold text-primary mb-3" onchange="switchCamera()">
                            <option value="">Đang tải dữ liệu...</option>
                        </select>

                        <div class="p-2 bg-white border rounded small shadow-sm text-break">
                            <span class="fw-bold text-dark"><i class="bi bi-link-45deg text-primary"></i> Đang dùng:</span><br />
                            <span id="currentVideoName" class="text-danger fw-bold">Chưa có dữ liệu</span>
                        </div>
                    </div>

                    <div class="mt-auto border-top pt-3">
                        <div class="alert alert-info py-2 small shadow-sm">
                            <i class="bi bi-info-circle-fill me-1"></i> Hệ thống tự động kích hoạt AI khi bạn chọn Camera.
                        </div>
                        <button class="btn btn-outline-danger btn-sm w-100 fw-bold" type="button" onclick="stopAI()">
                            <i class="bi bi-power me-1"></i> TẮT MÀN HÌNH
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col text-center mb-4">
            <h3 class="text-primary fw-bold mb-3"><i class="bi bi-camera-video text-danger"></i> CAMERA GIÁM SÁT REAL-TIME</h3>
            <div class="card shadow-lg border-0 bg-dark">
                <div id="video-container" class="card-body p-0 position-relative d-flex justify-content-center align-items-center" style="width: 100%; min-height: 600px; overflow: hidden;">

                    <div id="offlineMsg" class="text-secondary text-center" style="z-index: 3;">
                        <i class="bi bi-eye-slash-fill" style="font-size: 5rem;"></i>
                        <h4 class="mt-3 text-light" id="statusText">Màn hình đang tắt</h4>
                        <p class="small">Vui lòng chọn Camera để bắt đầu giám sát.</p>
                    </div>

                    <img id="video-stream" src="" class="img-fluid" alt="Live Stream" style="display: none; width: 100%; max-height: 800px; object-fit: contain; position: relative; z-index: 1;" />
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        let allCameras = [];

        function saveUIState() {
            var camId = $('#cameraSelect').val();
            if (camId) localStorage.setItem('sharedCameraId', camId);
        }

        function updateVideoFileNameDisplay() {
            let selectedId = $('#cameraSelect').val();
            if (!selectedId) {
                $('#currentVideoName').text("Chưa có dữ liệu").removeClass('text-success text-primary').addClass('text-danger');
                return;
            }

            let selectedCam = allCameras.find(c => c.id == selectedId);
            if (selectedCam && selectedCam.duongDan) {
                let isStream = selectedCam.duongDan.startsWith('http') || selectedCam.duongDan.startsWith('rtsp');
                if(isStream) {
                    $('#currentVideoName').text(selectedCam.duongDan).removeClass('text-danger text-success').addClass('text-primary');
                } else {
                    $('#currentVideoName').text(selectedCam.duongDan).removeClass('text-danger text-primary').addClass('text-success');
                }
            }
        }

        function loadCamerasFromDB() {
            $.ajax({
                url: '/api/api/camera/list',
                type: 'GET',
                success: function(res) {
                    if(res.status === 'success' && res.data) {
                        allCameras = res.data;
                        let html = '';
                        allCameras.forEach(cam => { html += `<option value="${cam.id}">${cam.tenCamera}</option>`; });
                        $('#cameraSelect').html(html);

                        var lastCam = localStorage.getItem('sharedCameraId');
                        if (lastCam && $(`#cameraSelect option[value='${lastCam}']`).length > 0) {
                            $('#cameraSelect').val(lastCam);
                        }
                        updateVideoFileNameDisplay();
                    }
                }
            });
        }

        // HÀM TỰ ĐỘNG CHUYỂN ĐỔI: TẮT CŨ -> BẬT MỚI
        async function switchCamera() {
            let cameraId = $('#cameraSelect').val();
            if (!cameraId) return;

            saveUIState();
            updateVideoFileNameDisplay();

            // 1. Hiển thị trạng thái đang chuyển đổi
            $('#video-stream').hide();
            $('#offlineMsg').show();
            $('#statusText').html('<div class="spinner-border text-primary mb-3"></div><br/>Đang chuyển kết nối...');

            // 2. Gửi lệnh tắt AI cũ ngầm (không hiện confirm)
            await $.post('/api/api/ai/stop');

            // 3. Tự động gửi lệnh bật AI mới
            var formData = new FormData();
            formData.append("cameraId", cameraId);

            $.ajax({
                url: '/api/api/ai/start',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    let img = document.getElementById('video-stream');
                    let retryCount = 0;

                    img.onload = function() {
                        $(img).show();
                        $('#offlineMsg').hide();
                    };

                    img.onerror = function() {
                        if (retryCount < 5) {
                            retryCount++;
                            setTimeout(() => {
                                img.src = "http://127.0.0.1:5000/video_feed?t=" + new Date().getTime();
                            }, 1000);
                        } else {
                            $(img).hide();
                            $('#offlineMsg').show();
                            $('#statusText').text("Lỗi kết nối Video");
                        }
                    };

                    // Chờ 1 giây cho Python khởi động rồi mới gán src
                    setTimeout(() => {
                        img.src = "http://127.0.0.1:5000/video_feed?t=" + new Date().getTime();
                    }, 1000);
                },
                error: function () {
                    $('#statusText').text("Lỗi khởi động hệ thống AI");
                }
            });
        }

        function stopAI() {
            if(!confirm("Xác nhận tắt màn hình giám sát?")) return;
            $.ajax({
                url: '/api/api/ai/stop',
                type: 'POST',
                success: function (res) {
                    $('#video-stream').hide().attr("src", "");
                    $('#offlineMsg').show();
                    $('#statusText').text("Màn hình đã tắt");
                }
            });
        }

        $(document).ready(function () {
            loadCamerasFromDB();

            // Tự động kết nối lại nếu AI đang chạy sẵn khi load trang
            let img = document.getElementById('video-stream');
            img.onload = function() { $(img).show(); $('#offlineMsg').hide(); };
            img.src = "http://127.0.0.1:5000/video_feed?t=" + new Date().getTime();
        });
    </script>
}